# ============================================================
# Agentic Pipeline - Configuração de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores.

# Ambiente de execução: "local" ou "databricks"
RUNTIME_ENV=local

# Caminho base para tabelas Delta Lake (modo local)
DATA_ROOT=./data

# Caminho para o arquivo parquet de origem
BRONZE_SOURCE_PATH=./conversations_bronze.parquet

# ============================================================
# Configuração do LLM
# ============================================================
# Modelo/provider primário do LLM (formato LiteLLM)
# Exemplos:
#   OpenAI:    gpt-4o-mini
#   Anthropic: anthropic/claude-3-haiku-20240307
#   Google:    gemini/gemini-1.5-flash
#   Ollama:    ollama/llama3
#   Ollama:    ollama/mistral
LLM_MODEL=gpt-4o-mini

# Modelo de fallback (usado quando o primário falha)
LLM_FALLBACK_MODEL=ollama/llama3

# API Keys (defina apenas as que você utiliza)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# URL base do Ollama (necessário apenas para Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Controle de custo do LLM: gasto máximo em USD por execução do pipeline
LLM_MAX_COST_PER_RUN=5.00

# Temperatura do LLM (0.0 - 1.0)
LLM_TEMPERATURE=0.1

# ============================================================
# Configuração do Pipeline
# ============================================================
# Intervalo de polling em segundos para o agente monitor
MONITOR_POLL_INTERVAL=60

# Tamanho do lote para processamento LLM (conversas por lote)
LLM_BATCH_SIZE=15

# ============================================================
# Configuração do Frontend
# ============================================================
STREAMLIT_PORT=8501
