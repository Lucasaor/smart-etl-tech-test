# ============================================================
# Agentic Pipeline - Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.

# Runtime environment: "local" or "databricks"
RUNTIME_ENV=local

# Base path for Delta Lake tables (local mode)
DATA_ROOT=./data

# Path to the source parquet file
BRONZE_SOURCE_PATH=./conversations_bronze.parquet

# ============================================================
# LLM Configuration
# ============================================================
# Primary LLM provider/model (LiteLLM format)
# Examples:
#   OpenAI:    gpt-4o-mini
#   Anthropic: anthropic/claude-3-haiku-20240307
#   Google:    gemini/gemini-1.5-flash
#   Ollama:    ollama/llama3
#   Ollama:    ollama/mistral
LLM_MODEL=gpt-4o-mini

# Fallback model (used when primary fails)
LLM_FALLBACK_MODEL=ollama/llama3

# API Keys (set only the ones you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Ollama base URL (only needed for Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# LLM cost control: max USD spend per pipeline run
LLM_MAX_COST_PER_RUN=5.00

# LLM temperature (0.0 - 1.0)
LLM_TEMPERATURE=0.1

# ============================================================
# Pipeline Configuration
# ============================================================
# Polling interval in seconds for the monitor agent
MONITOR_POLL_INTERVAL=60

# Batch size for LLM processing (conversations per batch)
LLM_BATCH_SIZE=15

# ============================================================
# Frontend Configuration
# ============================================================
STREAMLIT_PORT=8501
